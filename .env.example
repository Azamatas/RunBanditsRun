# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=color
LOGS_DIR=logs

# Database
DATABASE_URL=postgresql://runbandits:runbandits@localhost:5432/runbandits

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Common Activity Fréchet Distance Thresholds
# Minimum distance (meters) between common activities of the same sport — reject creation if closer
COMMON_ACTIVITY_MIN_FRECHET_DISTANCE_METERS=100.0
# Distance threshold (meters) for auto-linking activities to common activities
COMMON_ACTIVITY_LINK_FRECHET_DISTANCE_METERS=50.0
