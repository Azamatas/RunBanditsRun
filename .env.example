# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=color
LOGS_DIR=logs

# Database
DATABASE_URL=postgresql://runbandits:runbandits@localhost:5432/runbandits

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Common Activity Detection
COMMON_ACTIVITY_DETECTION_ENABLED=true
COMMON_ACTIVITY_DETECTION_INTERVAL_SECONDS=10
COMMON_ACTIVITY_DETECTION_CLUSTER_THRESHOLD=50.0
COMMON_ACTIVITY_DETECTION_MIN_ACTIVITIES=3
COMMON_ACTIVITY_DETECTION_MIN_LENGTH=100.0
